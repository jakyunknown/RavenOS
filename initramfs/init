#!/bin/sh
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev

mkdir -p /mnt/root /mnt/overlay /mnt/newroot

for dev in /dev/sr0 /dev/sda /dev/sdb /dev/vda; do
    mount -t squashfs $dev /mnt/root 2>/dev/null && break
    mount -t iso9660 $dev /mnt/root 2>/dev/null && break
done

ISO_MOVED=0
if [ ! -e /mnt/root/init ] && [ -f /mnt/root/boot/raven.squashfs ]; then
    mkdir -p /mnt/isoroot
    mount --move /mnt/root /mnt/isoroot
    mount -t squashfs -o loop /mnt/isoroot/boot/raven.squashfs /mnt/root
    ISO_MOVED=1
fi

mount -t tmpfs tmpfs /mnt/overlay
mkdir -p /mnt/overlay/upper /mnt/overlay/work

mount -t overlay overlay \
  -o lowerdir=/mnt/root,upperdir=/mnt/overlay/upper,workdir=/mnt/overlay/work \
  /mnt/newroot

# --- Persistent config: find and apply the raven-persist partition ---
# Wait briefly for block devices to settle before looking for persistent partition
i=0
while [ $i -lt 5 ]; do
    PERSIST_DEV=$(findfs LABEL=raven-persist 2>/dev/null)
    [ -n "$PERSIST_DEV" ] && break
    sleep 1
    i=$((i + 1))
done
if [ -n "$PERSIST_DEV" ]; then
    mkdir -p /mnt/persist
    if mount "$PERSIST_DEV" /mnt/persist 2>/dev/null; then
        if [ -d /mnt/persist/etc ]; then
            cp -a /mnt/persist/etc/. /mnt/newroot/etc/
        fi
        umount /mnt/persist
    fi
fi

if [ "$ISO_MOVED" = "1" ]; then
    mkdir -p /mnt/newroot/mnt/isoroot
    mount --move /mnt/isoroot /mnt/newroot/mnt/isoroot
fi

exec switch_root /mnt/newroot /sbin/init
