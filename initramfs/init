#!/bin/sh
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev

mkdir -p /mnt/root /mnt/overlay/upper /mnt/overlay/work /mnt/newroot

# Mount the squashfs read-only (adjust device as needed once we test)
mount -t squashfs /dev/vda /mnt/root 2>/dev/null || \
mount -t squashfs /dev/vda /mnt/root 2>/dev/null

# RAM-backed writable layer
mount -t tmpfs tmpfs /mnt/overlay

mkdir -p /mnt/overlay/upper /mnt/overlay/work

mount -t overlay overlay \
  -o lowerdir=/mnt/root,upperdir=/mnt/overlay/upper,workdir=/mnt/overlay/work \
  /mnt/newroot

exec switch_root /mnt/newroot /sbin/init
